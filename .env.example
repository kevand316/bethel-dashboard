# Public — safe to expose in client code
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# NEVER commit the real values of anything below.
# These should ONLY exist in your local .env (which is gitignored)
# or in your Supabase dashboard / Vercel env vars.

# Service role key — full database access, bypasses RLS. Server-side only.
# DO NOT use this in any client code, ever.
# SUPABASE_SERVICE_ROLE_KEY=

# SMTP credentials (if using custom email provider for password resets)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
